{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/brunovicco/engineering-loop-schemas/schemas/evidence.schema.json",
  "title": "Evidence-Gated Engineering Loop Evidence",
  "description": "Mechanical, reproducible record of exactly what was run against exactly which commits, with hashed outputs. Evidence is what hard gates are graded from; it is produced by running acceptance.hard_gates' commands, never asserted by a builder.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "run_id",
    "contract_id",
    "baseline_sha",
    "candidate_sha",
    "environment",
    "commands",
    "changed_files",
    "usage",
    "started_at",
    "finished_at"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "run_id": {
      "type": "string",
      "description": "Unique identifier for this loop run (e.g. a UUID4 or ULID).",
      "minLength": 1
    },
    "contract_id": {
      "type": "string",
      "minLength": 1
    },
    "baseline_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "candidate_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["python", "uv_lock_sha256", "tool_versions"],
      "properties": {
        "python": {
          "type": "string",
          "description": "Python version used to run the gates, e.g. '3.13.13'."
        },
        "uv_lock_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "SHA-256 of uv.lock at candidate_sha, binding evidence to an exact dependency set."
        },
        "tool_versions": {
          "type": "object",
          "description": "Mapping of tool name to resolved version, e.g. {'ruff': '0.15.21', 'mypy': '2.3.0'}.",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "exit_code", "stdout_sha256", "duration_s"],
        "properties": {
          "command": { "type": "string", "minLength": 1 },
          "exit_code": { "type": "integer" },
          "stdout_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "duration_s": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "changed_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "model", "tokens"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "tokens": {
          "type": "object",
          "additionalProperties": false,
          "required": ["input", "output"],
          "properties": {
            "input": { "type": "integer", "minimum": 0 },
            "output": { "type": "integer", "minimum": 0 }
          }
        },
        "estimated_cost_usd": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
